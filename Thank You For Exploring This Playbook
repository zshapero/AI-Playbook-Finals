<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Leadership Playbook - Thank You</title>
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@400;700&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            font-family: 'Open Sans', sans-serif;
            background: #ffffff;
            color: #333;
            line-height: 1.8;
            margin: 0;
            padding: 0;
            width: 2050px;
            font-size: 24px;
        }

        .page-wrapper {
            display: flex;
            width: 2050px;
            align-items: stretch;
        }

        .main-content {
            flex: 1;
            max-width: 1700px;
            padding: 60px 100px;
        }

        .Module-label {
            font-family: 'Open Sans', sans-serif;
            font-size: 20px;
            font-weight: 600;
            color: #FF7600;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 8px;
        }

        h1 {
            font-family: 'Merriweather', serif;
            font-size: 56px;
            font-weight: 700;
            color: #0B38DB;
            margin-bottom: 28px;
            line-height: 1.3;
        }

        .intro-text {
            font-size: 28px;
            color: #555;
            margin-bottom: 0;
        }

        /* Intro Section with Image */
        .intro-section {
            display: flex;
            align-items: flex-start;
            gap: 60px;
            margin-bottom: 48px;
            padding-bottom: 36px;
            border-bottom: 2px solid #f0f0f0;
            position: relative;
        }

        .intro-content {
            flex: 1;
        }

        .intro-image {
            flex-shrink: 0;
            width: 340px;
            height: auto;
            max-height: 400px;
            object-fit: contain;
            align-self: flex-end;
            margin-bottom: -80px;
        }

        h2 {
            font-family: 'Merriweather', serif;
            font-size: 38px;
            font-weight: 700;
            color: #0B38DB;
            margin-top: 56px;
            margin-bottom: 24px;
        }

        h3 {
            font-family: 'Open Sans', sans-serif;
            font-size: 30px;
            font-weight: 600;
            color: #FF7600;
            margin-top: 36px;
            margin-bottom: 16px;
        }

        p {
            margin-bottom: 16px;
            font-size: 24px;
        }

        /* Action Items Box */
        .action-box {
            background: #f8f9ff;
            border-left: 5px solid #0B38DB;
            padding: 36px 40px;
            margin: 40px 0;
            border-radius: 0 12px 12px 0;
        }

        .action-box h3 {
            color: #0B38DB;
            margin-top: 0;
            margin-bottom: 16px;
            font-size: 32px;
        }

        .action-box p {
            color: #555;
            margin-bottom: 24px;
            font-size: 24px;
        }

        .check-list {
            margin: 24px 0;
            padding-left: 0;
            list-style: none;
        }

        .check-list li {
            position: relative;
            padding-left: 36px;
            margin-bottom: 16px;
            color: #444;
            font-size: 24px;
            line-height: 1.6;
        }

        .check-list li::before {
            content: "✓";
            position: absolute;
            left: 0;
            color: #27ae60;
            font-weight: 600;
            font-size: 26px;
        }

        /* Action Items with Preview Layout */
        .action-box-with-preview {
            display: flex;
            gap: 48px;
            align-items: flex-start;
        }

        .action-box-content {
            flex: 1;
            min-width: 0;
        }

        .screenshot-preview {
            flex-shrink: 0;
            width: 420px;
        }

        .screenshot-placeholder {
            background: linear-gradient(135deg, #f5f7fa 0%, #e8ecf1 100%);
            border: 3px dashed #0B38DB;
            border-radius: 12px;
            aspect-ratio: 8.5 / 11;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            box-shadow: 0 8px 24px rgba(11, 56, 219, 0.15);
        }

        .screenshot-placeholder::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 40px;
            background: linear-gradient(90deg, #0B38DB 0%, #FF7600 100%);
            opacity: 0.9;
        }

        .screenshot-inner {
            padding: 60px 24px 24px;
            text-align: center;
            width: 100%;
        }

        .screenshot-icon {
            font-size: 72px;
            margin-bottom: 16px;
            opacity: 0.7;
        }

        .screenshot-title {
            font-family: 'Open Sans', sans-serif;
            font-size: 18px;
            font-weight: 600;
            color: #0B38DB;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .screenshot-subtitle {
            font-size: 14px;
            color: #666;
            line-height: 1.5;
        }

        .screenshot-mockup-lines {
            width: 80%;
            margin-top: 20px;
        }

        .mockup-line {
            height: 10px;
            background: rgba(11, 56, 219, 0.15);
            border-radius: 5px;
            margin-bottom: 12px;
        }

        .mockup-line:nth-child(2) {
            width: 70%;
            margin-left: 15%;
        }

        .mockup-line:nth-child(3) {
            width: 85%;
            margin-left: 7.5%;
        }

        .mockup-line:nth-child(4) {
            width: 60%;
            margin-left: 20%;
        }

        .mockup-checkboxes {
            margin-top: 20px;
            text-align: left;
            padding: 0 20px;
        }

        .mockup-checkbox {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 12px;
        }

        .mockup-checkbox-box {
            width: 16px;
            height: 16px;
            border: 2px solid #0B38DB;
            border-radius: 3px;
            flex-shrink: 0;
        }

        .mockup-checkbox-line {
            height: 8px;
            background: rgba(11, 56, 219, 0.12);
            border-radius: 4px;
            flex: 1;
        }

        .coming-soon-tag {
            display: inline-block;
            background: #FF7600;
            color: #fff;
            padding: 6px 16px;
            border-radius: 6px;
            font-size: 18px;
            font-weight: 600;
            margin-left: 8px;
            vertical-align: middle;
        }

        /* Stay Tuned Section */
        .stay-tuned-section {
            margin-top: 64px;
            padding-top: 48px;
            border-top: 2px solid #f0f0f0;
        }

        .Module-section {
            margin: 36px 0;
        }

        .Module-title {
            font-family: 'Open Sans', sans-serif;
            font-size: 26px;
            font-weight: 600;
            color: #FF7600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 16px;
        }

        .chapter-list {
            margin: 0 0 0 32px;
            padding: 0;
            list-style: none;
        }

        .chapter-list li {
            position: relative;
            padding-left: 28px;
            margin-bottom: 14px;
            color: #444;
            font-size: 24px;
            line-height: 1.6;
        }

        .chapter-list li::before {
            content: "•";
            position: absolute;
            left: 0;
            color: #0B38DB;
            font-weight: 600;
            font-size: 28px;
        }

        .closing-text {
            font-family: 'Merriweather', serif;
            font-size: 32px;
            font-style: italic;
            color: #0B38DB;
            margin-top: 48px;
            margin-bottom: 48px;
        }

        /* Download Section */
        .download-section {
            background: #0B38DB;
            color: #fff;
            padding: 36px 44px;
            margin: 48px 0;
            border-radius: 12px;
            text-align: center;
        }

        .download-section h3 {
            font-family: 'Merriweather', serif;
            color: #fff;
            font-size: 34px;
            margin: 0 0 16px 0;
        }

        .download-section p {
            color: rgba(255,255,255,0.9);
            font-size: 24px;
            margin-bottom: 24px;
        }

        .download-btn {
            display: inline-block;
            background: #fff;
            color: #0B38DB;
            border: none;
            padding: 16px 40px;
            border-radius: 8px;
            font-size: 22px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.2s ease, transform 0.2s ease;
        }

        .download-btn:hover {
            background: #f0f4ff;
            transform: translateY(-2px);
        }

        .download-btn-secondary {
            background: #FF7600 !important;
            color: #fff !important;
        }

        .download-btn-secondary:hover {
            background: #e66a00 !important;
            transform: translateY(-2px);
        }

        .download-instructions {
            color: #ffffff;
            font-size: 18px;
            font-style: italic;
            display: block;
            margin-top: 16px;
        }

        /* Resource Sidebar */
        .resource-sidebar {
            width: 350px;
            background: #f9f9f9;
            border-left: 1px solid #e0e0e0;
            padding: 24px 24px;
            flex-shrink: 0;
        }

        .sidebar-header {
            font-family: 'Open Sans', sans-serif;
            font-size: 23px;
            font-weight: 600;
            color: #0B38DB;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 28px;
            padding-bottom: 16px;
            border-bottom: 2px solid #FF7600;
        }

        .resource-section {
            margin-bottom: 28px;
        }

        .resource-section-title {
            font-size: 20px;
            font-weight: 600;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 16px;
        }

        .resource-item {
            display: block;
            background: #fff;
            border: 1px solid #e8e8e8;
            border-radius: 6px;
            padding: 22px;
            margin-bottom: 14px;
            cursor: pointer;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
            text-decoration: none;
            color: inherit;
        }

        .resource-item:hover {
            border-color: #0B38DB;
            box-shadow: 0 2px 8px rgba(11, 56, 219, 0.1);
        }

        .resource-item-tag {
            display: inline-block;
            font-size: 15px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 5px 12px;
            border-radius: 3px;
            margin-bottom: 10px;
        }

        .resource-item-tag.download {
            background: #e8f0fe;
            color: #0B38DB;
        }

        .resource-item-title {
            font-size: 22px;
            font-weight: 600;
            color: #333;
            margin-bottom: 6px;
        }

        .resource-item-desc {
            font-size: 21px;
            color: #666;
            line-height: 1.5;
        }

        .resource-item-learn-more {
            display: block;
            font-size: 21px;
            font-weight: 600;
            color: #0B38DB;
            margin-top: 12px;
        }

        .resource-item:hover .resource-item-learn-more {
            text-decoration: underline;
        }

        @media print {
            .download-section,
            .resource-sidebar {
                display: none;
            }
            .page-wrapper {
                width: 100%;
            }
            .main-content {
                max-width: 100%;
                padding: 20px;
            }
        }

        @media (max-width: 1800px) {
            body {
                width: 100%;
            }
            .page-wrapper {
                width: 100%;
            }
            .main-content {
                padding: 40px 60px;
            }
            .resource-sidebar {
                width: 300px;
            }
        }

        @media (max-width: 900px) {
            .page-wrapper {
                flex-direction: column;
            }
            .main-content {
                max-width: 100%;
                padding: 32px 24px;
            }
            .resource-sidebar {
                width: 100%;
                border-left: none;
                border-top: 1px solid #e0e0e0;
            }
            .intro-section {
                flex-direction: column;
            }
            .intro-image {
                width: 200px;
                height: auto;
            }
        }
    </style>

<style>
.screenshot-placeholder::before { display: none !important; }
</style>

</head>
<body>
    <div class="page-wrapper">
    <main class="main-content">
        <!-- Intro Section with Image -->
        <div class="intro-section">
            <div class="intro-content">
                <img src="data:image/png;base64," style="width:180px;height:auto;display:block;margin:-40px 0 10px 0;">
